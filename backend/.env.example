# Copy to .env and adjust. The backend reads these on startup.
PKM_DATABASE_URL=postgresql://pkm:pkm@localhost:5432/pkm
PKM_VAULT_DIR=./vault
PKM_API_TOKEN=dev-local-token-change-me

# Embeddings: "ollama" (local, default) or "api" (fallback)
PKM_EMBEDDER=ollama
PKM_EMBED_MODEL=nomic-embed-text
PKM_EMBED_DIM=768
PKM_OLLAMA_URL=http://localhost:11434

# Only used when PKM_EMBEDDER=api
PKM_API_EMBED_URL=https://api.openai.com/v1/embeddings
PKM_API_EMBED_KEY=
PKM_API_EMBED_MODEL=text-embedding-3-small
